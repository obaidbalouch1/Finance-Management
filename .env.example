# --- Database (Neon Postgres) ---
# Pooled connection string (used at runtime, via @prisma/adapter-neon)
DATABASE_URL="postgresql://user:password@ep-example-pooler.us-east-2.aws.neon.tech/finance_manager?sslmode=require"
# Direct (unpooled) connection string, used by Prisma Migrate
DIRECT_URL="postgresql://user:password@ep-example.us-east-2.aws.neon.tech/finance_manager?sslmode=require"

# --- Auth.js ---
# Generate with: npx auth secret  (or: openssl rand -base64 33)
AUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Optional OAuth providers (leave blank to disable)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# --- Vercel Blob (receipt uploads) ---
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxxxxx"

# --- Optional SMTP (password reset emails). Falls back to console logging if unset ---
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="Finance Manager <no-reply@finance-manager.app>"

# --- Cron (protects /api/cron/* routes called by Vercel Cron) ---
CRON_SECRET="replace-with-a-long-random-secret"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Finance Manager"

# Seed script: creates this admin user on first `pnpm db:seed`
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"
